{
  "name": "chat-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:deps": "cd ../ts-sdks && pnpm install --frozen-lockfile && pnpm --filter @socialproof/myso-messaging-stack build",
