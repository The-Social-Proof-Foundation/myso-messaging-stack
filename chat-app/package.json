    "@socialproof/myso-messaging-stack": "link:../ts-sdks/packages/myso-messaging-stack",
    "@socialproof/myso-groups": "^0.0.2",
    "@socialproof/mydata": "^0.0.4",
    "@socialproof/myso": "^0.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
