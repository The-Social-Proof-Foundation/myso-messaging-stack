# MySo Network — genesis package IDs (0x2 / 0xe110 / 0x50c1) and shared object IDs
# are resolved automatically via GraphQL. Only network + endpoint URLs are required.
VITE_MYSO_NETWORK=testnet
VITE_MYSO_RPC_URL=https://fullnode.testnet.mysocial.network:9000
VITE_MYSO_GRAPHQL_URL=https://graphql.testnet.mysocial.network/graphql

# Relayer
VITE_RELAYER_URL=http://localhost:3000

# Social server (optional — enables DM block pre-check in SDK)
# VITE_SOCIAL_SERVER_URL=https://social.testnet.mysocial.network

# Postgres (relayer production): STORAGE_TYPE=postgres DATABASE_URL=postgres://...

# File Storage (testnet defaults)
VITE_FILE_STORAGE_PUBLISHER_URL=https://publisher.file-storage-testnet.mysocial.network
VITE_FILE_STORAGE_AGGREGATOR_URL=https://aggregator.file-storage-testnet.mysocial.network
VITE_FILE_STORAGE_EPOCHS=5

# MyData Key Servers (threshold encryption)
# Testnet: use two or more object IDs; threshold defaults to 2.
# VITE_MYDATA_KEY_SERVER_OBJECT_IDS=0x...,0x...
# Localnet: copy parent KEY_SERVER_OBJECT_ID from `myso start --with-mydata` (http://127.0.0.1:2024).
# Must be key_server::KeyServer — verify: `myso client object <id>` (NOT dynamic_field::Field<…KeyServerV1>).
# After --force-regenesis: update this value, restart `pnpm dev`, and re-faucet your dev signer.
# Local key-server accepts @socialproof/mydata SDK >=0.0.4 (ts_sdk_version_requirement in generated yaml).
# VITE_MYDATA_KEY_SERVER_OBJECT_IDS=0x...
# VITE_MYDATA_THRESHOLD=1

# MySocial Auth — register redirect URI with MySocial per client ID.
VITE_MYSOCIAL_AUTH_API_BASE_URL=https://api.mysocial.network
VITE_MYSOCIAL_AUTH_ORIGIN=https://auth.mysocial.network
VITE_MYSOCIAL_AUTH_CLIENT_ID=your-platform-client-id
VITE_MYSOCIAL_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_MYSOCIAL_SALT_URL=https://salt.testnet.mysocial.network/salt

# Local dev only — keep false when testing real MySocial OAuth wallet identity
VITE_DEV_UNBLOCK_MESSAGING_UI=false
