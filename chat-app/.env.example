# MySo Network — genesis package IDs (0x2 / 0xe110 / 0x50c1) and shared object IDs
# are resolved automatically via GraphQL. Only network + endpoint URLs are required.
#
# Railway deploy (Root Directory: chat-app): copy these as service variables in the
# Railway dashboard before deploy — Vite inlines VITE_* at build time.
# - Use full VITE_MYSO_GRAPHQL_URL (not /api/graphql; that Vite proxy is dev-only).
# - Set VITE_RELAYER_URL to your deployed relayer public URL.
# - Set VITE_MYSOCIAL_AUTH_REDIRECT_URI to https://<your-app>.up.railway.app/auth/callback
#   and register that URI with MySocial for your client ID.

VITE_MYSO_NETWORK=testnet
VITE_MYSO_RPC_URL=https://fullnode.testnet.mysocial.network:9000
VITE_MYSO_GRAPHQL_URL=https://graphql.testnet.mysocial.network/graphql

# Relayer
VITE_RELAYER_URL=http://localhost:3000

# Social server (optional — paid policy reads, DM block/gate pre-checks in SDK)
# Testnet:
# VITE_SOCIAL_SERVER_URL=https://social.testnet.mysocial.network
# Localnet (`myso start --with-social-indexer`):
# VITE_SOCIAL_SERVER_URL=http://127.0.0.1:9126

# --- Localnet example (uncomment and adjust after `myso start --with-faucet --with-mydata --with-graphql --with-social-indexer`) ---
# VITE_MYSO_NETWORK=localnet
# VITE_MYSO_GRAPHQL_URL=http://127.0.0.1:9125/graphql
# VITE_SOCIAL_SERVER_URL=http://127.0.0.1:9126
# JSON-RPC (local fullnode; Vite dev proxies via /api/rpc to avoid CORS):
# VITE_MYSO_RPC_URL=http://127.0.0.1:9001

# Postgres (relayer production): STORAGE_TYPE=postgres DATABASE_URL=postgres://...

# File Storage (testnet defaults)
VITE_FILE_STORAGE_PUBLISHER_URL=https://publisher.file-storage-testnet.mysocial.network
VITE_FILE_STORAGE_AGGREGATOR_URL=https://aggregator.file-storage-testnet.mysocial.network
VITE_FILE_STORAGE_EPOCHS=5

# Optional: portable history recovery via relayer R2 archive (opt-in)
# Requires relayer ARCHIVE_BACKEND=r2 with matching ARCHIVE_NAMESPACE.
# Uses VITE_RELAYER_URL — no separate archive service.
# VITE_ENABLE_MESSAGE_RECOVERY=true
# VITE_ARCHIVE_NAMESPACE=mysocial

# MyData Key Servers (threshold encryption)
# Testnet: use two or more object IDs; threshold defaults to 2.
# VITE_MYDATA_KEY_SERVER_OBJECT_IDS=0x...,0x...
# Localnet: copy parent KEY_SERVER_OBJECT_ID from `myso start --with-mydata` (http://127.0.0.1:2024).
# Must be key_server::KeyServer — verify: `myso client object <id>` (NOT dynamic_field::Field<…KeyServerV1>).
# After --force-regenesis: update this value, restart `pnpm dev`, and re-faucet your dev signer.
# Local key-server accepts @socialproof/mydata SDK >=0.0.4 (ts_sdk_version_requirement in generated yaml).
# VITE_MYDATA_KEY_SERVER_OBJECT_IDS=0x...
# VITE_MYDATA_THRESHOLD=1

# MySocial Auth — register redirect URI with MySocial per client ID.
# apiBaseUrl = salt service origin (SDK calls /auth/refresh and /auth/logout here).
# SALT_URL = full /salt path for keypair derivation POST (separate from apiBaseUrl).
VITE_MYSOCIAL_AUTH_API_BASE_URL=https://salt.testnet.mysocial.network
VITE_MYSOCIAL_AUTH_ORIGIN=https://auth.testnet.mysocial.network
VITE_MYSOCIAL_AUTH_CLIENT_ID=your-platform-client-id
VITE_MYSOCIAL_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_MYSOCIAL_SALT_URL=https://salt.testnet.mysocial.network/salt

# Public MySocial web app (profile deep links from chat nav → /wallet?address=…)
# VITE_MYSOCIAL_WEB_ORIGIN=https://www.mysocial.network

# Local dev only — keep false when testing real MySocial OAuth wallet identity
VITE_DEV_UNBLOCK_MESSAGING_UI=false

# Optional: shared Platform object ID for paid-DM escrow claims.
# When set, platform fees route to Platform.treasury on-chain.
# When unset, fees route to the ecosystem treasury (0x0 sentinel).
# VITE_PLATFORM_ID=0x...
