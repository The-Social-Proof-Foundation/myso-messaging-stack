# MySo Network
VITE_MYSO_NETWORK=testnet
VITE_MYSO_RPC_URL=https://fullnode.testnet.mysocial.network:9000
VITE_MYSO_GRAPHQL_URL=https://graphql.testnet.mysocial.network/graphql

# Package IDs (only needed for localnet/devnet; auto-detected for testnet/mainnet)
# VITE_PERMISSIONED_GROUPS_ORIGINAL_PACKAGE_ID=0x...
# VITE_PERMISSIONED_GROUPS_LATEST_PACKAGE_ID=0x...
# VITE_MESSAGING_GROUPS_ORIGINAL_PACKAGE_ID=0x...
# VITE_MESSAGING_GROUPS_LATEST_PACKAGE_ID=0x...
# VITE_MESSAGING_GROUPS_NAMESPACE_ID=0x...
# VITE_MESSAGING_GROUPS_VERSION_ID=0x...

# Relayer
VITE_RELAYER_URL=http://localhost:3000

# File Storage (testnet defaults)
VITE_FILE_STORAGE_PUBLISHER_URL=https://publisher.file-storage-testnet.mysocial.network
VITE_FILE_STORAGE_AGGREGATOR_URL=https://aggregator.file-storage-testnet.mysocial.network
VITE_FILE_STORAGE_EPOCHS=5

# MyData Key Servers (threshold encryption)
# VITE_MYDATA_KEY_SERVER_OBJECT_IDS=0x...,0x...

# MySocial Auth — register redirect URI with MySocial per client ID.
# NOTE: API_BASE_URL is the auth backend API (e.g. https://api.mysocial.network), NOT the salt service.
VITE_MYSOCIAL_AUTH_API_BASE_URL=https://api.mysocial.network
VITE_MYSOCIAL_AUTH_ORIGIN=https://auth.mysocial.network
VITE_MYSOCIAL_AUTH_CLIENT_ID=your-platform-client-id
VITE_MYSOCIAL_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_MYSOCIAL_SALT_URL=https://salt.testnet.mysocial.network/salt

# Local dev only: when salt/OAuth key derivation fails or session is wallet-only, use a
# browser-persisted ephemeral Ed25519 key so the chat UI and messaging client can load.
# On-chain identity is this keypair’s address — not your MySocial-linked wallet.
# VITE_DEV_UNBLOCK_MESSAGING_UI=true
